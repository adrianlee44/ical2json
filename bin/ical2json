#!/usr/bin/env node

/**
 * ical2json
 * https://github.com/adrianlee44/ical2json
 *
 * Copyright (c) 2017 Adrian Lee
 * Licensed under the MIT license.
 */

import {readFileSync} from 'node:fs';
import {dirname, join} from 'node:path';
import {fileURLToPath} from 'node:url';
import {program} from 'commander';

const dir = join(dirname(fileURLToPath(import.meta.url)), '../');
const pkg = JSON.parse(readFileSync(new URL('../package.json', import.meta.url), 'utf8'));

program
  .version(pkg.version)
  .option('-o, --output-dir <path>', 'Output directory')
  .option('-r, --revert', 'Revert JSON to ical')
  .option('-s, --stdout', 'Output to stdout')
  .usage('[options] [FILES...]')
  .parse(process.argv);

if (program.args.length) {
  const {default: run} = await import(join(dir, 'build/cli.js'));
  const output = run(program.args, program.opts());
  process.exit(Number(!output));
} else {
  // eslint-disable-next-line no-console
  console.log(program.helpInformation());
}
