{
  "name": "ical2json",
  "version": "4.1.3",
  "description": "A simple node package to convert ical to JSON",
  "type": "module",
  "main": "build/ical2json.js",
  "types": "build/ical2json.d.ts",
  "files": [
    "bin/icaljson",
    "build/cli.js",
    "build/constants.js",
    "build/ical2json.js",
    "build/ical2json.d.ts",
    "build/utils.js"
  ],
  "scripts": {
    "compile": "tsc",
    "prepublishOnly": "npm run clean; npm run compile",
    "lint": "eslint .",
    "test": "npm run clean; npm run lint; tsc; npm run coverage; npm run report",
    "report": "nyc report --reporter=lcov",
    "coverage": "nyc ava",
    "clean": "rm -rf coverage/ build/"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/adrianlee44/ical2json.git"
  },
  "bugs": {
    "url": "https://github.com/adrianlee44/ical2json/issues"
  },
  "keywords": [
    "ical",
    "json",
    "converter"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "author": "Adrian Lee",
  "license": "MIT",
  "bin": {
    "ical2json": "bin/ical2json"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@types/sinon": "^21.0.0",
    "ava": "^7.0.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "execa": "^9.6.1",
    "nyc": "^18.0.0",
    "prettier": "^3.8.1",
    "sinon": "^21.0.3",
    "tempy": "^3.2.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2"
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "ava": {
    "extensions": [
      "ts"
    ],
    "nodeArguments": [
      "--import=tsx"
    ]
  },
  "nyc": {
    "include": [
      "src"
    ]
  }
}
